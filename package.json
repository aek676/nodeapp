{
  "name": "nodeapp",
  "version": "1.0.0",
  "description": "",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/main",
    "test": "jest",
    "test-jenkins": "jest --reporters=default --reporters=jest-junit",
    "coverage-jenkins": "jest --reporters=default --reporters=jest-junit --coverage --coverageReporters=text --coverageReporters=html --coverageDirectory=./coverage/",
    "lint": "eslint src/**/*.js -f checkstyle -o coverage/eslint-result.xml"
  },
  "jest-junit": {
    "outputDirectory": "./coverage/",
    "outputName": "test.results.xml",
    "usePathForSuiteName": "true"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.17.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-checkstyle": "^9.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^27.5.1",
    "jest-junit": "^13.0.0",
    "prettier": "^3.8.1",
    "supertest": "^6.2.2"
  }
}
